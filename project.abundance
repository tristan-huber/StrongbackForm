              "interpreterVersion": 1,
              "code": "function run(input: Assembly) {\n  const result = new Assembly(input);\n\n  result.onLeafs((leaf) => {\n    const projection = replicad.drawProjection(leaf.geometry, \"top\");\n\n    const organised = replicad.organiseBlueprints(\n      projection.visible._innerShape\n    );\n\n    console.log(organised)\n\n    const outerBlueprints = organised.map((b) =>\n      \"blueprints\" in b ? b.blueprints : b\n    );\n\n    // Build a child Assembly for each island, then return a branch\n    // that contains all of them.\n    const islandAssemblies = outerBlueprints.map(\n      (bp) =>\n        new Assembly({\n          geometry: new replicad.Drawing(bp),\n          color: leaf.color,\n          tags: leaf.tags,\n          bom: leaf.bom,\n        })\n    );\n\n    const branch = new Assembly();\n    branch.geometry = islandAssemblies;\n    return branch;\n  });\n\n  return result;\n}",
              "compiledCode": "\"use strict\";\nfunction run(input) {\n    const result = new Assembly(input);\n    result.onLeafs((leaf) => {\n        const projection = replicad.drawProjection(leaf.geometry, \"top\");\n        const organised = replicad.organiseBlueprints(projection.visible._innerShape);\n        console.log(organised);\n        const outerBlueprints = organised.map((b) => \"blueprints\" in b ? b.blueprints : b);\n        // Build a child Assembly for each island, then return a branch\n        // that contains all of them.\n        const islandAssemblies = outerBlueprints.map((bp) => new Assembly({\n            geometry: new replicad.Drawing(bp),\n            color: leaf.color,\n            tags: leaf.tags,\n            bom: leaf.bom,\n        }));\n        const branch = new Assembly();\n        branch.geometry = islandAssemblies;\n        return branch;\n    });\n    return result;\n}\n"
            },

                {
                  "atomType": "Code",
                  "x": 0.39583333333333337,
                  "y": 0.43714285714285717,
                  "uniqueID": "id-14096",
                  "ioValues": [
                    {
                      "name": "toMove",
                      "ioValue": "__GEOMETRY_INPUT__"
                    },
                    {
                      "name": "offsets",
                      "ioValue": [
                        "-47.25",
                        "-24",

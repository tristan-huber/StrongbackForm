                },
                {
                  "atomType": "Code",
                  "x": 0.46223958333333337,
                  "y": 0.21714285714285714,
                  "uniqueID": "id-16171",
                  "ioValues": [
                    {
                      "name": "toRotate",
                      "ioValue": "__GEOMETRY_INPUT__"
                    },
                    {
                      "name": "pivotPoint",
                      "ioValue": [
                        "-47.25",

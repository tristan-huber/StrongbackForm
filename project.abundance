            {
              "atomType": "Code",
              "x": 0.5696614583333334,
              "y": 0.5771428571428572,
              "uniqueID": "id-21307",
              "ioValues": [
                {
                  "name": "input",
                  "ioValue": "__GEOMETRY_INPUT__"
                }
              ],
              "interpreterVersion": 1,
              "code": "/**\n * Projects the perimeter of every leaf in an Assembly tree onto the XY plane\n * (top-down view) and returns a matching Assembly tree of 2-D Drawings.\n *\n * @param input  Any Assembly (single leaf or nested tree) to project.\n * @returns      A mirrored Assembly tree where each leaf is a 2-D Drawing\n *               of the visible silhouette from above.\n */\nfunction run(input: Assembly) {\n  // Deep-copy the input so we don't mutate the upstream assembly.\n  let result = new Assembly(input);\n\n  result = result.onLeafs((leaf) => {\n    // Project this leaf's solid onto the XY plane (looking down -Z).\n    if (!leaf.is3D()) {\n      return leaf;\n    }\n    const { visible, hidden } = replicad.drawProjection(leaf.geometry, \"XY\");\n\n    let i = 1;\n    let boundary = visible;\n    if (\"blueprints\" in visible.innerShape) {\n      console.warn(\"Compound geometry. This may not work correctly\")\n    }\n\n    leaf.plane = new replicad.Plane(\"XY\")\n    leaf.geometry = boundary\n\n    return leaf;\n  });\n\n  return result;\n}",
              "compiledCode": "\"use strict\";\n/**\n * Projects the perimeter of every leaf in an Assembly tree onto the XY plane\n * (top-down view) and returns a matching Assembly tree of 2-D Drawings.\n *\n * @param input  Any Assembly (single leaf or nested tree) to project.\n * @returns      A mirrored Assembly tree where each leaf is a 2-D Drawing\n *               of the visible silhouette from above.\n */\nfunction run(input) {\n    // Deep-copy the input so we don't mutate the upstream assembly.\n    let result = new Assembly(input);\n    result = result.onLeafs((leaf) => {\n        // Project this leaf's solid onto the XY plane (looking down -Z).\n        if (!leaf.is3D()) {\n            return leaf;\n        }\n        const { visible, hidden } = replicad.drawProjection(leaf.geometry, \"XY\");\n        let i = 1;\n        let boundary = visible;\n        if (\"blueprints\" in visible.innerShape) {\n            console.warn(\"Compound geometry. This may not work correctly\");\n        }\n        leaf.plane = new replicad.Plane(\"XY\");\n        leaf.geometry = boundary;\n        return leaf;\n    });\n    return result;\n}\n"
            },
